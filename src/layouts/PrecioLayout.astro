---
import { render, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DirectAnswer from '@/components/DirectAnswer.astro';
import PriceTable from '@/components/PriceTable.astro';
import PriceCalculator from '@/components/islands/PriceCalculator.astro';
import Faq from '@/components/Faq.astro';
import UpdatedDate from '@/components/UpdatedDate.astro';
import CtaBlock from '@/components/CtaBlock.astro';
import { seoFromEntry } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { entryLocale, servicioPath } from '@/lib/paths';
import { staticPath } from '@/i18n/routes';
import { useTranslations } from '@/i18n/ui';

/** Price-guide template: freshness date is prominent; methodology note is mandatory (GEO evidence density). */
interface Props {
  entry: CollectionEntry<'precios'>;
}
const { entry } = Astro.props;
const locale = entryLocale(entry.id);
const t = useTranslations(locale);
const seo = await seoFromEntry('precios', entry);
const { Content } = await render(entry);
const relatedServicio = entry.data.relatedServicio ? await getEntry(entry.data.relatedServicio) : undefined;

const crumbs = [
  { name: t('breadcrumb.inicio'), path: locale === 'en' ? '/en/' : '/' },
  { name: t('nav.precios'), path: staticPath('precios-hub', locale) },
  { name: entry.data.shortLabel, path: seo.canonicalPath },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(entry.data.faq)]}>
  <Breadcrumbs items={crumbs} />
  <article class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <header class="max-w-3xl">
      <h1 class="text-3xl leading-tight text-forest-900 sm:text-4xl lg:text-[2.75rem]">{entry.data.h1}</h1>
      <UpdatedDate date={entry.data.dateModified} locale={locale} />
      <DirectAnswer text={entry.data.directAnswer} />
      {/* Evidence note — models cite evidence-dense content measurably more */}
      <p class="mt-3 text-sm italic text-ink-soft">{entry.data.metodologia}</p>
    </header>

    <PriceTable priceKey={entry.data.priceKey} locale={locale} />

    {entry.data.showCalculator && <PriceCalculator locale={locale} />}

    <div class="prose-aleto mt-10 max-w-3xl">
      <Content />
    </div>

    {
      relatedServicio && (
        <p class="mt-8">
          <a href={servicioPath(relatedServicio)} class="font-medium text-forest-700 underline decoration-chartreuse-400 decoration-2 underline-offset-2 hover:text-forest-900">
            {relatedServicio.data.h1} →
          </a>
        </p>
      )
    }

    <Faq faq={entry.data.faq} locale={locale} />
    <CtaBlock locale={locale} />
  </article>
</BaseLayout>
