---
import { getEntries, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import GalleryGrid from '@/components/GalleryGrid.astro';
import EstimateSection from '@/components/EstimateSection.astro';
import TestimonialsBlock from '@/components/TestimonialsBlock.astro';
import StatsBand from '@/components/StatsBand.astro';
import Faq from '@/components/Faq.astro';
import { seoFromEntry } from '@/lib/seo';
import { faqSchema, serviceSchema } from '@/lib/schema';
import { entryLocale, servicioPath } from '@/lib/paths';
import { staticPath } from '@/i18n/routes';
import { useTranslations } from '@/i18n/ui';
import { whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';
import WhatsAppIcon from '@/components/WhatsAppIcon.astro';

/**
 * Wolf-blueprint service page (2026-07-19 full CRO rebuild): hero →
 * gallery → capability cards → estimate form → reviews (gated) →
 * related services. Image-first, short copy, NO prices anywhere.
 * The markdown body is intentionally not rendered (content kept in the
 * .md files — reversible). Meta/FAQ schema still derive from frontmatter.
 */
interface Props {
  entry: CollectionEntry<'servicios'>;
}
const { entry } = Astro.props;
const locale = entryLocale(entry.id);
const t = useTranslations(locale);
const seo = await seoFromEntry('servicios', entry);

const related = (await getEntries(entry.data.relatedServices)).filter((r) => !r.data.draft);

const crumbs = [
  { name: t('breadcrumb.inicio'), path: locale === 'en' ? '/en/' : '/' },
  { name: t('nav.servicios'), path: staticPath('servicios-hub', locale) },
  { name: entry.data.shortLabel, path: seo.canonicalPath },
];

const waMessage = WHATSAPP_DEFAULT_MSG[locale];
const ui = {
  es: {
    btn: 'Presupuesto por WhatsApp',
    btnForm: 'Pedir presupuesto gratis',
    micro: 'Respuesta hoy · Visita gratuita · Sin compromiso',
    chips: ['Asegurados (RC 300.000 €)', 'Garantía por escrito', 'Fechas por contrato'],
    featuresTitle: 'Así trabajamos',
  },
  en: {
    btn: 'Quote via WhatsApp',
    btnForm: 'Get a free estimate',
    micro: 'Reply today · Free visit · No obligation',
    chips: ['Insured (€300k liability)', 'Written guarantee', 'Dates in the contract'],
    featuresTitle: 'How we work',
  },
}[locale];
---

<BaseLayout seo={seo} schemas={[serviceSchema(entry, seo.canonicalPath), faqSchema(entry.data.faq)]}>
  <Breadcrumbs items={crumbs} />

  {/* Hero: short, visual, conversion-first */}
  <header class="bg-brand-gradient text-paper">
    <div class="mx-auto grid max-w-6xl items-center gap-8 px-4 py-12 sm:px-6 sm:py-16 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <h1 class="text-3xl leading-tight sm:text-4xl lg:text-[2.75rem]">{entry.data.h1}</h1>
        <p class="mt-4 max-w-xl text-lg leading-relaxed text-paper/90">{entry.data.heroLead}</p>
        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href={whatsappLink(waMessage)}
            data-pos="hero"
            class="inline-flex items-center gap-2 rounded-full bg-paper px-6 py-3.5 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]"
          >
            <WhatsAppIcon size={15} />
            {ui.btn}
          </a>
          <a href="#contacto" class="rounded-full border border-paper/50 px-6 py-3.5 text-sm font-semibold text-paper hover:border-paper">
            {ui.btnForm}
          </a>
        </div>
        <p class="mt-4 text-xs font-medium text-paper/80">{ui.micro}</p>
        <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-2">
          {ui.chips.map((c) => (
            <li class="flex items-center gap-1.5 text-sm text-paper/90">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="text-chartreuse-300"><path d="M2 6.5 4.8 9.2 10 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {c}
            </li>
          ))}
        </ul>
      </div>
      {
        entry.data.image && (
          <div class="overflow-hidden rounded-2xl border border-paper/20">
            <Image
              src={entry.data.image}
              alt={entry.data.serviceName}
              widths={[600, 900, 1200]}
              sizes="(min-width: 1024px) 520px, 100vw"
              class="aspect-[4/3] w-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        )
      }
    </div>
  </header>

  {/* Work gallery */}
  {
    entry.data.gallery.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pt-10 sm:px-6">
        <GalleryGrid items={entry.data.gallery} />
      </section>
    )
  }

  {/* Capability cards (Wolf feature grid) */}
  {
    entry.data.features.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
        <h2 class="text-2xl text-forest-900 sm:text-3xl">{ui.featuresTitle}</h2>
        <div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {entry.data.features.map((f) => (
            <FeatureCard icon={f.icon} title={f.title} text={f.text} />
          ))}
        </div>
      </section>
    )
  }

  <EstimateSection locale={locale} formSource={`servicio_${entry.id.replace('/', '_')}`} />

  <TestimonialsBlock locale={locale} />

  <StatsBand locale={locale} />

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <Faq faq={entry.data.faq} locale={locale} />
    {
      related.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl text-forest-900">{t('related.servicios')}</h2>
          <ul class="mt-4 flex flex-wrap gap-3">
            {related.map((r) => (
              <li>
                <a href={servicioPath(r)} class="inline-block rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-forest-800 hover:border-olive-400 hover:text-forest-700">
                  {r.data.shortLabel}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</BaseLayout>
