---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DirectAnswer from '@/components/DirectAnswer.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import Faq from '@/components/Faq.astro';
import UpdatedDate from '@/components/UpdatedDate.astro';
import CtaBlock from '@/components/CtaBlock.astro';
import { seoFromSingleLocale } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { proyectoPath } from '@/lib/paths';
import { useTranslations } from '@/i18n/ui';

/**
 * Programmatic zone template (docs/02 §5). Render order: H1 → direct answer
 * with ZONE pricing → services grid → housing-stock paragraph (the
 * anti-doorway substance) → real projects → zone reviews → barrios → FAQ → CTA.
 * Only reached by zonas that passed the quality gate in getStaticPaths.
 */
interface Props {
  zona: CollectionEntry<'zonas'>;
}
const { zona } = Astro.props;
const t = useTranslations('es');
const d = zona.data;
const [pMin, pMax] = d.precio_pintar_piso_80m2;
const nf = new Intl.NumberFormat('es-ES');

const directAnswer = `Pintar un piso de 80 m² en ${d.nombre} cuesta entre ${nf.format(pMin)} € y ${nf.format(pMax)} € en 2026, según el estado de las paredes. ${d.notas_precio}`;

const seo = seoFromSingleLocale('zonas', zona, {
  title: `Pintores en ${d.nombre} — Precios 2026`,
  description: `Empresa de pintura en ${d.nombre} (${d.tipo === 'distrito' ? 'Madrid' : 'Comunidad de Madrid'}). Pintar un piso de 80 m² desde ${nf.format(pMin)} €. Presupuesto en 24 h.`,
});

const servicios = (await getCollection('servicios', (e) => e.id.startsWith('es/'))).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const allProyectos = await getCollection('proyectos');
const proyectos = allProyectos.filter((p) => d.proyectos.includes(p.id.replace(/^es\//, '')) || d.proyectos.includes(p.id));
const allReviews = await getCollection('reviews');
const reviews = allReviews.filter((r) => d.reviews.includes(r.data.id));

const faq = [
  {
    q: `¿Cuánto cuesta pintar un piso en ${d.nombre}?`,
    a: `Un piso de 80 m² en ${d.nombre} cuesta entre ${nf.format(pMin)} € y ${nf.format(pMax)} € (pintura interior completa, 2026). ${d.notas_precio}`,
  },
  {
    q: `¿Trabajáis en todo ${d.nombre}?`,
    a: `Sí, trabajamos en todo ${d.nombre}${d.barrios.length ? `: ${d.barrios.join(', ')}` : ''}. Hacemos visita y presupuesto cerrado gratis en 24 h.`,
  },
];

const crumbs = [
  { name: t('breadcrumb.inicio'), path: '/' },
  { name: `Pintores en ${d.nombre}`, path: seo.canonicalPath },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(faq)]}>
  <Breadcrumbs items={crumbs} />
  <article class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <header class="max-w-3xl">
      <h1 class="text-3xl leading-tight text-forest-900 sm:text-4xl lg:text-[2.75rem]">Pintores en {d.nombre}</h1>
      <UpdatedDate date={d.dateModified} locale="es" />
      <DirectAnswer text={directAnswer} />
    </header>

    <section class="mt-12">
      <h2 class="text-2xl text-forest-900 sm:text-3xl">Servicios de pintura en {d.nombre}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {servicios.map((s) => <ServiceCard servicio={s} locale="es" />)}
      </div>
    </section>

    {/* Housing-stock paragraph — zone-specific substance */}
    <section class="mt-14 max-w-3xl">
      <h2 class="text-2xl text-forest-900 sm:text-3xl">Cómo son las viviendas de {d.nombre}</h2>
      <p class="mt-4 leading-relaxed text-ink">{d.vivienda}</p>
      <p class="mt-3 leading-relaxed text-ink-soft">{d.notas_precio}</p>
    </section>

    {
      proyectos.length > 0 && (
        <section class="mt-14">
          <h2 class="text-2xl text-forest-900 sm:text-3xl">Trabajos realizados en {d.nombre}</h2>
          <ul class="mt-6 grid gap-4 sm:grid-cols-2">
            {proyectos.map((p) => (
              <li>
                <a href={proyectoPath(p)} class="block rounded-2xl border border-line bg-white p-5 hover:border-olive-400">
                  <h3 class="text-lg text-forest-900">{p.data.h1}</h3>
                  <p class="mt-1 text-sm text-ink-soft">
                    {p.data.superficieM2} m² · {nf.format(p.data.precioTotal)} € · {p.data.duracionDias} días
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      reviews.length > 0 && (
        <section class="mt-14">
          <h2 class="text-2xl text-forest-900 sm:text-3xl">Opiniones de clientes en {d.nombre}</h2>
          <ul class="mt-6 grid gap-4 sm:grid-cols-2">
            {reviews.map((r) => (
              <li class="rounded-2xl border border-line bg-white p-5">
                <p class="text-chartreuse-500" aria-label={`${r.data.rating} de 5`}>{'★'.repeat(r.data.rating)}</p>
                <p class="mt-2 text-sm leading-relaxed text-ink">"{r.data.texto}"</p>
                <p class="mt-3 text-xs font-medium text-ink-soft">{r.data.autor} · {r.data.fuente}</p>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      d.barrios.length > 0 && (
        <section class="mt-14 max-w-3xl">
          <h2 class="text-xl text-forest-900">Barrios donde trabajamos en {d.nombre}</h2>
          <p class="mt-3 text-ink-soft">{d.barrios.join(' · ')}</p>
        </section>
      )
    }

    <Faq faq={faq} locale="es" />
    <CtaBlock locale="es" message={`Hola, busco pintores en ${d.nombre}. ¿Me podéis dar un presupuesto?`} />
  </article>
</BaseLayout>
