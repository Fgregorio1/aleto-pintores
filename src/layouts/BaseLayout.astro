---
import '@/styles/global.css';
import '@fontsource-variable/fraunces';
import SEO from '@/components/seo/SEO.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import LangBanner from '@/components/islands/LangBanner.astro';
import MobileCta from '@/components/MobileCta.astro';
import Attribution from '@/components/islands/Attribution.astro';
import { BUSINESS } from '@/data/business';
import { businessSchema, webPageSchema, websiteSchema } from '@/lib/schema';
import type { SEOData } from '@/lib/seo';

/**
 * Every page renders through here: one SEOData in, one <head> out.
 * The HousePainter #business node is emitted site-wide — it's the entity
 * anchor for GBP/AI-model resolution (docs/02 §4).
 */
interface Props {
  seo: SEOData;
  /** Page-specific JSON-LD nodes (Service, FAQPage, BreadcrumbList…) */
  schemas?: (object | null)[];
}

const { seo, schemas = [] } = Astro.props;
const htmlLang = seo.locale === 'es' ? 'es' : 'en';
const switchUrl = seo.alternates.find((a) =>
  seo.locale === 'es' ? a.hreflang === 'en' : a.hreflang === 'es-ES',
)?.href;
const enTwin = seo.locale === 'es' ? seo.alternates.find((a) => a.hreflang === 'en')?.href : undefined;

const isThankYouPage = Astro.url.pathname.endsWith('/gracias/') || Astro.url.pathname.endsWith('/thank-you/');
const { googleAdsId, googleAdsConversionLabel } = BUSINESS;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#2a6445" />
    <SEO seo={seo} />
    <JsonLd schemas={[businessSchema(), websiteSchema(), webPageSchema(seo), ...schemas]} />
    {/* Zaraz manual install — the ONLY loader. Zaraz autoInjectScript is
        disabled zone-side (it injects a second copy for browser UAs →
        "zaraz is loaded twice"); if the error reappears, re-check that flag.
        Custom path (Zaraz settings.initPath) — /cdn-cgi/zaraz/* is on ad-block
        lists; /al/* is intercepted at the edge before our worker and matches
        no blocklist. 404s harmlessly in local dev. Loads consent + tools. */}
    <script is:inline src="/al/i.js"></script>

    {/* Google Ads gtag with Consent Mode v2: everything DENIED by default;
        granted only when the Zaraz consent modal's Marketing purpose ('marketing')
        is accepted. Denied-state gtag sends only cookieless pings (Google's
        EEA-required setup). Conversion firing lives in LeadForm (window.gtag). */}
    {googleAdsId && (
      <>
        <script is:inline define:vars={{ googleAdsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('consent', 'default', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: 'denied',
          });
          gtag('js', new Date());
          gtag('config', googleAdsId);

          function aletoSyncGoogleConsent() {
            var granted = !!(window.zaraz && zaraz.consent && zaraz.consent.get('marketing'));
            gtag('consent', 'update', {
              ad_storage: granted ? 'granted' : 'denied',
              ad_user_data: granted ? 'granted' : 'denied',
              ad_personalization: granted ? 'granted' : 'denied',
              analytics_storage: (window.zaraz && zaraz.consent && zaraz.consent.get('analitica')) ? 'granted' : 'denied',
            });
          }
          document.addEventListener('zarazConsentAPIReady', aletoSyncGoogleConsent);
          document.addEventListener('zarazConsentChoicesUpdated', aletoSyncGoogleConsent);
        </script>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleAdsId}`}></script>
      </>
    )}
  </head>
  <body class="flex min-h-screen flex-col pb-[72px] sm:pb-0">
    <Header locale={seo.locale} switchUrl={switchUrl} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={seo.locale} />
    {enTwin && <LangBanner enUrl={enTwin} />}
    <MobileCta locale={seo.locale} />
    <Attribution />
  </body>
</html>
