---
/**
 * First-party attribution + event layer (docs/04).
 * ~1 KB inline, no cookies (sessionStorage only — part of fulfilling the
 * visitor's own quote request), no third parties.
 *
 * 1. Captures the visit source once per session (utm_* > referrer > directo)
 * 2. Stamps every wa.me link with a "Ref: <source>" line so leads arrive
 *    in WhatsApp already labeled with their true origin
 * 3. Fires conversion events via zaraz.track() — a safe no-op until Zaraz
 *    is active. Events: whatsapp_click, phone_click (form_submit and
 *    calculator_complete fire from their own components via window.aletoTrack)
 */
---

<script>
  const KEY = 'aleto-src';
  try {
    if (!sessionStorage.getItem(KEY)) {
      const p = new URLSearchParams(location.search);
      let src = '';
      const utm = p.get('utm_source');
      if (utm) {
        src = utm + (p.get('utm_campaign') ? '/' + p.get('utm_campaign') : '');
      } else if (document.referrer) {
        try {
          const h = new URL(document.referrer).hostname.replace(/^www\./, '');
          if (!h.includes('aletopintores.com')) {
            const map: Record<string, string> = {
              'google.': 'google-organic',
              'bing.': 'bing-organic',
              'duckduckgo.': 'ddg-organic',
              'chatgpt.com': 'chatgpt',
              'perplexity.': 'perplexity',
              'facebook.': 'facebook',
              'instagram.': 'instagram',
              'l.instagram': 'instagram',
            };
            const hit = Object.entries(map).find(([k]) => h.includes(k));
            src = hit ? hit[1] : h;
          }
        } catch {}
      }
      sessionStorage.setItem(KEY, src || 'directo');
    }
  } catch {}

  const src = (() => {
    try {
      return sessionStorage.getItem(KEY) || 'directo';
    } catch {
      return 'directo';
    }
  })();

  // Platform click IDs for the offline-conversion loop (docs/04): unlike the
  // source label (first-touch), these UPDATE whenever present — a newer ad
  // click wins. Persisted per session so they survive navigation to the form.
  const clickIds: Record<string, string> = {};
  try {
    const p = new URLSearchParams(location.search);
    for (const k of ['gclid', 'wbraid', 'fbclid']) {
      const v = p.get(k);
      if (v) sessionStorage.setItem('aleto-' + k, v);
      clickIds[k] = sessionStorage.getItem('aleto-' + k) || '';
    }
  } catch {}
  (window as any).aletoClickIds = clickIds;

  // Expose for LeadForm / PriceCalculator scripts
  (window as any).aletoSrc = src;
  const track = (name: string, props: Record<string, unknown> = {}) => {
    try {
      (window as any).zaraz?.track?.(name, props);
    } catch {}
    try {
      // PostHog runs as a Zaraz Custom HTML tool (consent-gated), which
      // doesn't consume zaraz.track events — capture directly when loaded.
      (window as any).posthog?.capture?.(name, props);
    } catch {}
  };
  (window as any).aletoTrack = track;

  // Stamp all prefilled WhatsApp links with the source
  document.querySelectorAll<HTMLAnchorElement>('a[href^="https://wa.me"]').forEach((a) => {
    try {
      const u = new URL(a.href);
      const t = u.searchParams.get('text') || '';
      if (t && !/\bRef:/.test(t)) {
        u.searchParams.set('text', t + '\nRef: ' + src);
        a.href = u.toString();
      }
    } catch {}
  });

  // service slug from the URL (docs/04 event property)
  const service = (() => {
    const m = location.pathname.match(/^\/(?:servicios|en\/services)\/([^/]+)/);
    return m ? m[1] : '';
  })();

  // ── Consent modal language normalizer ────────────────────────────────
  // Zaraz picks the modal language from the BROWSER's Accept-Language at
  // the edge; product decision: the modal must match the PAGE language.
  // The modal lives in an open shadow root — rewrite its strings to the
  // page language. Strings MUST stay in sync with the Zaraz config
  // (docs/tracking/04-analytics-tracking.md).
  const pageLang = document.documentElement.lang === 'en' ? 'en' : 'es';
  const CONSENT_TEXT = {
    es: {
      intro:
        '<span class="al-title">Cookies, elegidas por ti</span>' +
        'Solo usamos cookies si tú quieres: nos ayudan a saber qué funciona en la web y a mejorar nuestra publicidad. ' +
        'Cambia tu elección cuando quieras — más detalles en la <a href="/politica-privacidad/">política de privacidad</a>.',
      purposes: [
        ['Analítica', 'Nos ayuda a entender qué páginas y servicios interesan más, para mejorar la web. Los datos no se usan para publicidad.'],
        ['Marketing', 'Permite medir nuestras campañas de Google y Meta y mostrar anuncios más relevantes.'],
      ],
      accept: 'Aceptar todo',
      reject: 'Rechazar todo',
      save: 'Confirmar mi elección',
    },
    en: {
      intro:
        '<span class="al-title">Cookies, your call</span>' +
        'We only use cookies if you say so: they help us see what works and improve our advertising. ' +
        'Change your choice anytime — details in our <a href="/en/privacy-policy/">privacy policy</a>.',
      purposes: [
        ['Analytics', 'Helps us understand which pages and services interest visitors most, to improve the site. Not used for advertising.'],
        ['Marketing', 'Lets us measure our Google and Meta campaigns and show more relevant ads.'],
      ],
      accept: 'Accept all',
      reject: 'Reject all',
      save: 'Confirm my choices',
    },
  }[pageLang];

  let normalized = false;
  const normalizeModal = () => {
    const host = [...document.querySelectorAll('div')].find((el) =>
      el.shadowRoot?.querySelector?.('dialog.cf_modal'),
    );
    const sr = host?.shadowRoot;
    if (!sr) return false;
    const intro = sr.querySelector('p.cf_consent-intro');
    if (intro) intro.innerHTML = CONSENT_TEXT.intro;
    sr.querySelectorAll('li.cf_consent-element').forEach((li, i) => {
      const t = CONSENT_TEXT.purposes[i];
      if (!t) return;
      const h = li.querySelector('h3');
      const p = li.querySelector('label p, p');
      if (h) h.textContent = t[0];
      if (p) p.textContent = t[1];
    });
    const btn = (sel: string, txt: string) => {
      const b = sr.querySelector(sel);
      if (b) b.textContent = txt;
    };
    btn('.cf_button--accept', CONSENT_TEXT.accept);
    btn('.cf_button--reject', CONSENT_TEXT.reject);
    btn('.cf_button--save', CONSENT_TEXT.save);
    normalized = true;
    return true;
  };

  document.addEventListener('zarazConsentAPIReady', () => normalizeModal());
  // Fallback for event/script ordering: retry briefly until the modal exists
  let tries = 0;
  const iv = setInterval(() => {
    if (normalizeModal() || ++tries > 33) clearInterval(iv);
  }, 300);

  // Delegated conversion events
  document.addEventListener('click', (e) => {
    const a = (e.target as Element | null)?.closest?.('a[href]') as HTMLAnchorElement | null;
    if (!a) return;
    const base = {
      page: location.pathname,
      source: src,
      service,
      locale: document.documentElement.lang,
      position: (a as HTMLElement).dataset.pos || '',
    };
    if (a.href.startsWith('https://wa.me')) track('whatsapp_click', base);
    else if (a.href.startsWith('tel:')) track('phone_click', base);
  });
</script>
