---
import { BUSINESS, whatsappLink } from '@/data/business';
import type { Locale } from '@/i18n/ui';

/**
 * Zero-backend lead form: composes a structured WhatsApp message
 * (speed-to-lead — this is Spain, WhatsApp beats email). Falls back to a
 * mailto: link. Swap for a webhook (Make/n8n) later without touching markup.
 */
interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const txt = {
  es: {
    nombre: 'Tu nombre',
    zona: 'Zona / barrio',
    servicio: '¿Qué necesitas pintar?',
    servicioPh: 'Ej.: piso de 80 m² con gotelé en Chamberí',
    enviar: 'Enviar por WhatsApp',
    oEmail: 'o escríbenos a',
    nota: 'Al pulsar se abre WhatsApp con tu mensaje listo para enviar. Respondemos en el día.',
  },
  en: {
    nombre: 'Your name',
    zona: 'Area / neighbourhood',
    servicio: 'What do you need painted?',
    servicioPh: 'E.g.: 80 m² flat with gotelé in Chamberí',
    enviar: 'Send via WhatsApp',
    oEmail: 'or email us at',
    nota: 'This opens WhatsApp with your message ready to send. We reply the same day.',
  },
}[locale];
---

<form id="contact-form" class="mt-8 max-w-xl space-y-5" data-wa-base={whatsappLink()} data-locale={locale}>
  <label class="block text-sm font-medium text-forest-900">
    {txt.nombre}
    <input type="text" name="nombre" required class="mt-1.5 w-full rounded-lg border border-line bg-white px-3 py-2.5 text-sm" />
  </label>
  <label class="block text-sm font-medium text-forest-900">
    {txt.zona}
    <input type="text" name="zona" class="mt-1.5 w-full rounded-lg border border-line bg-white px-3 py-2.5 text-sm" />
  </label>
  <label class="block text-sm font-medium text-forest-900">
    {txt.servicio}
    <textarea name="detalle" rows="4" required placeholder={txt.servicioPh} class="mt-1.5 w-full rounded-lg border border-line bg-white px-3 py-2.5 text-sm"></textarea>
  </label>
  <button type="submit" class="rounded-full bg-forest-700 px-7 py-3 text-sm font-semibold text-paper transition-colors hover:bg-forest-800">
    {txt.enviar}
  </button>
  <p class="text-xs text-ink-soft">
    {txt.nota}
    {txt.oEmail}
    <a href={`mailto:${BUSINESS.email}`} class="font-medium text-forest-700 underline underline-offset-2">{BUSINESS.email}</a>
  </p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (ev) => {
      ev.preventDefault();
      const data = new FormData(form);
      const es = form.dataset.locale === 'es';
      const lines = es
        ? [
            `Hola, soy ${data.get('nombre')}.`,
            data.get('zona') ? `Zona: ${data.get('zona')}.` : '',
            `Necesito: ${data.get('detalle')}`,
            '¿Me podéis dar un presupuesto?',
          ]
        : [
            `Hi, I'm ${data.get('nombre')}.`,
            data.get('zona') ? `Area: ${data.get('zona')}.` : '',
            `I need: ${data.get('detalle')}`,
            'Could you give me a quote?',
          ];
      const msg = lines.filter(Boolean).join('\n');
      window.open(`${form.dataset.waBase}?text=${encodeURIComponent(msg)}`, '_blank');
    });
  }
</script>
