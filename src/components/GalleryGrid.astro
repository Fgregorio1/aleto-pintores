---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Wolf-blueprint image grid. Feed real job photos as they arrive;
 * interim stock keeps process-descriptive captions and is never
 * presented as our own projects.
 */
interface Item {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}
interface Props {
  items: Item[];
  cols?: 2 | 3;
}
const { items, cols = 3 } = Astro.props;
---

<div class:list={['grid gap-4', cols === 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2']}>
  {
    items.map((g) => (
      <figure class="overflow-hidden rounded-2xl border border-line bg-white">
        <Image
          src={g.src}
          alt={g.alt}
          widths={[400, 700, 1000]}
          sizes={cols === 3 ? '(min-width: 640px) 360px, 100vw' : '(min-width: 640px) 550px, 100vw'}
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
        />
        {g.caption && <figcaption class="px-4 py-3 text-xs font-medium text-ink-soft">{g.caption}</figcaption>}
      </figure>
    ))
  }
</div>
