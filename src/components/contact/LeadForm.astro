---
import type { Locale } from '@/i18n/ui';
import { staticPath } from '@/i18n/routes';
import { BUSINESS } from '@/data/business';
import Logo from '@/components/Logo.astro';
import { DIAL_CODES, PRIORITY_COUNTRIES, flagOf } from '@/data/dial-codes';

// Country options rendered at build time (zero client JS for the list):
// the 5 neighbours/priority countries first, then the whole world A→Z.
const priorityOptions = PRIORITY_COUNTRIES.map((iso) => ({
  iso,
  dial: DIAL_CODES[iso][0],
  label: `${flagOf(iso)} ${DIAL_CODES[iso][1]} +${DIAL_CODES[iso][0]}`,
}));
const restOptions = Object.entries(DIAL_CODES)
  .filter(([iso]) => !(PRIORITY_COUNTRIES as readonly string[]).includes(iso))
  .sort((a, b) => a[1][1].localeCompare(b[1][1], 'es'))
  .map(([iso, [dial, name]]) => ({ iso, dial, label: `${flagOf(iso)} ${name} +${dial}` }));

/**
 * Estimate-request form (ported from cm-painting ContactSection, Aleto brand,
 * no React — vanilla country-select phone field). Submits JSON to
 * /api/submit-lead (worker/index.ts) with attribution from sessionStorage;
 * success → /gracias/ | /en/thank-you/. RGPD checkbox required.
 */
interface Props {
  locale: Locale;
  formSource: string;
}
const { locale, formSource } = Astro.props;

const txt = {
  es: {
    heading1: 'Pide tu inspección y',
    headingFree: 'presupuesto GRATIS',
    heading2: 'hoy mismo',
    name: 'Nombre y apellidos*',
    phone: 'Teléfono*',
    email: 'Tu email*',
    help: '¿En qué te ayudamos?*',
    privacy1: 'He leído y acepto la',
    privacyLink: 'política de privacidad',
    submit: 'Pedir mi presupuesto gratis',
    sending: 'Enviando…',
    checks: ['Visita gratuita', 'Respuesta en menos de 24 h', 'Sin compromiso'],
    noSpam: 'Sin spam: solo te contactamos por tu presupuesto.',
    errName: 'Escribe tu nombre',
    errEmail: 'Revisa el email',
    errPhone: 'Revisa el teléfono (9 dígitos en España)',
    errService: 'Elige una opción',
    errPrivacy: 'Necesitamos tu consentimiento',
    errServer: 'No hemos podido enviar tu solicitud. Escríbenos por WhatsApp al 624 04 62 10 y te atendemos al momento.',
    thankUrl: '/gracias/',
  },
  en: {
    heading1: 'Schedule your',
    headingFree: 'FREE inspection & quote',
    heading2: 'today',
    name: 'First and last name*',
    phone: 'Phone*',
    email: 'Your email*',
    help: 'How can we help you?*',
    privacy1: 'I have read and accept the',
    privacyLink: 'privacy policy',
    submit: 'Request my free quote',
    sending: 'Sending…',
    checks: ['Free visit', 'Reply within 24 h', 'No obligation'],
    noSpam: 'No spam: we only contact you about your quote.',
    errName: 'Please enter your name',
    errEmail: 'Please check the email',
    errPhone: 'Please check the phone number',
    errService: 'Please choose an option',
    errPrivacy: 'We need your consent',
    errServer: "We couldn't send your request. Message us on WhatsApp at +34 624 04 62 10 and we'll reply right away.",
    thankUrl: '/en/thank-you/',
  },
}[locale];

const services = [
  { value: 'pintura-interior', es: 'Pintura interior', en: 'Interior painting' },
  { value: 'quitar-gotele', es: 'Quitar gotelé y alisar', en: 'Gotelé removal & smoothing' },
  { value: 'lacado-puertas', es: 'Lacado de puertas y armarios', en: 'Door & wardrobe lacquering' },
  { value: 'fachadas-comunidades', es: 'Fachadas y comunidades', en: 'Facades & communities' },
  { value: 'oficinas-locales', es: 'Oficinas y locales', en: 'Offices & retail' },
  { value: 'quitar-papel', es: 'Quitar papel pintado', en: 'Wallpaper removal' },
  { value: 'impermeabilizacion', es: 'Impermeabilizar terraza', en: 'Terrace waterproofing' },
  { value: 'otros', es: 'Otros', en: 'Others' },
];

const inputCls =
  'w-full rounded-lg border border-line bg-paper px-3 py-3 text-sm text-ink placeholder:text-ink-soft/70 focus:border-olive-400 focus:outline-none';
---

<div class="rounded-2xl border border-line bg-white p-6 shadow-sm sm:p-8">
  <div class="text-center">
    <Logo class="mx-auto h-8 w-auto text-forest-800" />
    <h2 class="mt-4 text-2xl leading-snug text-forest-900">
      {txt.heading1} <span class="underline decoration-chartreuse-400 decoration-4 underline-offset-4">{txt.headingFree}</span> {txt.heading2}
    </h2>
    <ul class="mt-3 flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs font-medium text-ink-soft">
      {txt.checks.map((c) => (
        <li class="flex items-center gap-1">
          <span class="text-forest-700" aria-hidden="true">✓</span>
          {c}
        </li>
      ))}
    </ul>
  </div>

  <form
    id="lead-form"
    class="mt-6 space-y-4"
    method="POST"
    action="/api/submit-lead"
    novalidate
    data-form-source={formSource}
    data-locale={locale}
    data-thank-url={txt.thankUrl}
    data-google-ads-id={BUSINESS.googleAdsId}
    data-google-ads-label={BUSINESS.googleAdsConversionLabel}
  >
    <div>
      <input type="text" name="full_name" required placeholder={txt.name} autocomplete="name" class={inputCls} />
      <p data-err="full_name" hidden class="mt-1 text-xs font-medium text-red-600">{txt.errName}</p>
    </div>

    <div>
      {/* Unified phone field: flag picker overlays an invisible select; dial code lives IN the input */}
      <div class="flex items-stretch rounded-lg border border-line bg-paper focus-within:border-olive-400" data-phone-box>
        <div class="relative flex shrink-0 items-center border-r border-line pl-3 pr-2">
          <span class="pointer-events-none select-none text-base" data-flag>{flagOf('ES')}</span>
          <span class="pointer-events-none ml-1 text-[0.6rem] text-ink-soft" aria-hidden="true">▾</span>
          <select
            name="phone_country"
            aria-label={locale === 'es' ? 'País del teléfono' : 'Phone country'}
            class="absolute inset-0 cursor-pointer opacity-0"
          >
            <optgroup label={locale === 'es' ? 'Frecuentes' : 'Frequent'}>
              {priorityOptions.map((c) => (
                <option value={c.iso} data-dial={c.dial} selected={c.iso === 'ES'}>{c.label}</option>
              ))}
            </optgroup>
            <optgroup label={locale === 'es' ? 'Todos los países' : 'All countries'}>
              {restOptions.map((c) => (
                <option value={c.iso} data-dial={c.dial}>{c.label}</option>
              ))}
            </optgroup>
          </select>
        </div>
        <input
          type="tel"
          name="phone_full"
          required
          value="+34 "
          aria-label={txt.phone}
          autocomplete="tel"
          inputmode="tel"
          class="w-full rounded-r-lg bg-transparent px-3 py-3 text-sm text-ink focus:outline-none"
        />
      </div>
      <p data-err="phone" hidden class="mt-1 text-xs font-medium text-red-600">{txt.errPhone}</p>
    </div>

    <div>
      <input type="email" name="email" required placeholder={txt.email} autocomplete="email" class={inputCls} />
      <p data-err="email" hidden class="mt-1 text-xs font-medium text-red-600">{txt.errEmail}</p>
    </div>

    <fieldset>
      <legend class="text-sm font-semibold text-forest-900">{txt.help}</legend>
      <div class="mt-2 space-y-2">
        {services.map((s) => (
          <label class="flex cursor-pointer items-center gap-2.5 text-sm text-ink">
            <input type="radio" name="service" value={s.value} class="h-4 w-4 accent-forest-700" />
            {locale === 'es' ? s.es : s.en}
          </label>
        ))}
      </div>
      <p data-err="service" hidden class="mt-1 text-xs font-medium text-red-600">{txt.errService}</p>
    </fieldset>

    <div>
      <label class="flex cursor-pointer items-start gap-2.5 text-xs text-ink-soft">
        <input type="checkbox" name="privacy" class="mt-0.5 h-4 w-4 accent-forest-700" />
        <span>
          {txt.privacy1}
          <a href={staticPath('politica-privacidad', locale)} target="_blank" class="font-medium text-forest-700 underline underline-offset-2">{txt.privacyLink}</a>*
        </span>
      </label>
      <p data-err="privacy" hidden class="mt-1 text-xs font-medium text-red-600">{txt.errPrivacy}</p>
    </div>

    {/* Honeypot — humans never see it */}
    <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

    <button
      type="submit"
      data-submit
      class="w-full rounded-full bg-forest-700 px-6 py-3.5 text-sm font-semibold text-paper transition-colors hover:bg-forest-800 disabled:opacity-60"
    >{txt.submit}</button>

    <p class="text-center text-[11px] text-ink-soft/80">{txt.noSpam}</p>

    <p data-err="server" hidden class="text-center text-xs font-medium text-red-600">{txt.errServer}</p>

    {/* Trust badges slot — add real Google/Facebook rating SVGs once reviews exist
    <div class="flex items-center justify-center gap-6 pt-2"> ... </div> */}
  </form>
</div>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  if (form) {
    const errs = form.querySelectorAll<HTMLElement>('[data-err]');
    const btn = form.querySelector<HTMLButtonElement>('[data-submit]')!;
    const btnLabel = btn.textContent;
    const sending = form.dataset.locale === 'es' ? 'Enviando…' : 'Sending…';
    const show = (field: string) => {
      form.querySelector<HTMLElement>(`[data-err="${field}"]`)?.removeAttribute('hidden');
    };
    const clear = () => errs.forEach((e) => e.setAttribute('hidden', ''));

    // ── CRO funnel events (docs/04 §1): form_start on first interaction,
    // form_abandon (with the last-touched field) if they leave mid-form ──
    const track = (name: string, props: Record<string, unknown> = {}) =>
      (window as any).aletoTrack?.(name, {
        form_source: form.dataset.formSource ?? 'home',
        locale: form.dataset.locale ?? 'es',
        page: location.pathname,
        ...props,
      });
    let started = false;
    let submitted = false;
    let lastField = '';
    form.addEventListener('focusin', (e) => {
      const el = e.target as HTMLElement;
      const name = el?.getAttribute?.('name');
      if (!name || name === 'company') return;
      lastField = name;
      if (!started) {
        started = true;
        track('form_start');
      }
    });
    window.addEventListener('pagehide', () => {
      if (started && !submitted) track('form_abandon', { last_field: lastField });
    });

    // ── Unified phone field: keep the select, flag and the +code inside the
    // input in sync in both directions ──
    const countrySel = form.querySelector<HTMLSelectElement>('[name=phone_country]')!;
    const flagEl = form.querySelector<HTMLElement>('[data-flag]')!;
    const phoneInput = form.querySelector<HTMLInputElement>('[name=phone_full]')!;
    const dialOf = (iso: string) =>
      countrySel.querySelector<HTMLOptionElement>(`option[value="${iso}"]`)?.dataset.dial ?? '34';
    const flagOf = (iso: string) =>
      String.fromCodePoint(...[...iso.toUpperCase()].map((c) => 0x1f1a5 + c.charCodeAt(0)));

    countrySel.addEventListener('change', () => {
      const dial = dialOf(countrySel.value);
      const national = phoneInput.value.replace(/^\+\d*\s*/, '');
      phoneInput.value = `+${dial} ${national}`;
      flagEl.textContent = flagOf(countrySel.value);
      phoneInput.focus();
    });

    // If the user hand-types a different +code, re-sync the picker (longest match wins)
    phoneInput.addEventListener('input', () => {
      const digits = phoneInput.value.replace(/^\+/, '').replace(/\D/g, '');
      if (!phoneInput.value.startsWith('+') || !digits) return;
      let best: HTMLOptionElement | null = null;
      countrySel.querySelectorAll<HTMLOptionElement>('option').forEach((o) => {
        const d = o.dataset.dial ?? '';
        if (digits.startsWith(d) && (!best || d.length > (best.dataset.dial ?? '').length)) best = o;
      });
      if (best && (best as HTMLOptionElement).value !== countrySel.value) {
        countrySel.value = (best as HTMLOptionElement).value;
        flagEl.textContent = flagOf(countrySel.value);
      }
    });

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      clear();
      const data = new FormData(form);
      const rawPhone = phoneInput.value.replace(/[\s\-().]/g, '');
      const payload: Record<string, string> = {
        full_name: String(data.get('full_name') ?? '').trim(),
        email: String(data.get('email') ?? '').trim(),
        phone: rawPhone.startsWith('+') ? rawPhone : rawPhone ? `+${dialOf(countrySel.value)}${rawPhone.replace(/^0+/, '')}` : '',
        phone_country: countrySel.value,
        zip_code: '',
        service: String(data.get('service') ?? ''),
        privacy: data.get('privacy') ? 'true' : 'false',
        form_source: form.dataset.formSource ?? 'home',
        locale: form.dataset.locale ?? 'es',
        page: location.pathname,
        company: String(data.get('company') ?? ''),
        source: (window as any).aletoSrc ?? 'directo',
      };
      // raw UTMs if present this session
      const q = new URLSearchParams(location.search);
      for (const k of ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'utm_id']) {
        payload[k] = q.get(k) || sessionStorage.getItem('aleto-' + k) || '';
      }
      // platform click IDs (session-persisted by Attribution.astro) — the key
      // to offline conversion uploads when a lead becomes a paying job
      const ids = ((window as any).aletoClickIds ?? {}) as Record<string, string>;
      for (const k of ['gclid', 'wbraid', 'gbraid', 'fbclid', 'fbp', 'fbc']) {
        payload[k] = ids[k] ?? '';
      }

      // client-side validation (mirrors worker rules)
      const failed: string[] = [];
      const fail = (f: string) => { show(f); failed.push(f); };
      if (payload.full_name.length < 2) fail('full_name');
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(payload.email)) fail('email');
      const phoneOk = payload.phone.startsWith('+34') ? /^\+34[6789]\d{8}$/.test(payload.phone) : /^\+\d{7,15}$/.test(payload.phone);
      if (!phoneOk) fail('phone');
      if (!payload.service) fail('service');
      if (payload.privacy !== 'true') fail('privacy');
      if (failed.length) {
        track('form_error', { kind: 'validation', fields: failed });
        return;
      }

      btn.disabled = true;
      btn.textContent = sending;
      try {
        const ctrl = new AbortController();
        const t = setTimeout(() => ctrl.abort(), 10000);
        const res = await fetch('/api/submit-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          signal: ctrl.signal,
        });
        clearTimeout(t);
        const out = await res.json().catch(() => ({}));
        if (res.ok && (out as any).success) {
          submitted = true;
          (window as any).aletoTrack?.('form_submit', {
            page: location.pathname,
            source: payload.source,
            service: payload.service,
            locale: payload.locale,
          });

          // Google Ads Enhanced Conversions trigger
          const adsId = form.dataset.googleAdsId;
          const adsLabel = form.dataset.googleAdsLabel;
          const thankUrl = form.dataset.thankUrl ?? '/gracias/';

          if (adsId && adsLabel && typeof (window as any).gtag === 'function') {
            let redirected = false;
            const doRedirect = () => {
              if (!redirected) {
                redirected = true;
                location.href = thankUrl;
              }
            };
            
            (window as any).gtag('event', 'conversion', {
              'send_to': `${adsId}/${adsLabel}`,
              'enhanced_conversion_data': {
                'email': payload.email,
                'phone_number': payload.phone
              },
              'event_callback': doRedirect
            });
            // Fallback safety timeout in case the callback is blocked/delayed
            setTimeout(doRedirect, 1000);
          } else {
            location.href = thankUrl;
          }
          return;
        }
        track('form_error', { kind: 'server', status: res.status });
        show('server');
      } catch {
        track('form_error', { kind: 'network' });
        show('server');
      }
      btn.disabled = false;
      btn.textContent = btnLabel;
    });
  }
</script>
