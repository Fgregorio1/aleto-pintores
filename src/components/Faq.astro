---
import { useTranslations, type Locale } from '@/i18n/ui';

/**
 * Visible FAQ rendered from the same frontmatter array that produces the
 * FAQPage schema (layout emits faqSchema(entry.data.faq)) — by construction
 * markup and schema can never diverge.
 */
interface Props {
  faq: { q: string; a: string }[];
  locale: Locale;
}
const { faq, locale } = Astro.props;
const t = useTranslations(locale);
---

{
  faq.length > 0 && (
    <section class="mt-16">
      <h2 class="text-2xl text-forest-900 sm:text-3xl">{t('faq.title')}</h2>
      <div class="mt-6 divide-y divide-line border-y border-line">
        {faq.map((item) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-medium text-forest-900 [&::-webkit-details-marker]:hidden">
              <h3 class="font-sans text-base font-medium tracking-normal">{item.q}</h3>
              <span class="text-olive-500 transition-transform group-open:rotate-45" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              </span>
            </summary>
            <p class="mt-3 max-w-3xl leading-relaxed text-ink-soft">{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
