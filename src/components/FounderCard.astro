---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { FOUNDER } from '@/data/business';
import type { Locale } from '@/i18n/ui';

/**
 * Visible founder block (docs/02 §7): the human behind the JSON-LD Person
 * node. Renders on the about pages only — same name/bio the schema claims.
 * Photo is optional so the card can ship before the headshot exists.
 */
interface Props {
  locale: Locale;
  photo?: ImageMetadata;
}
const { locale, photo } = Astro.props;
---

<aside class="mt-8 flex max-w-3xl flex-col gap-5 rounded-2xl border border-line bg-white p-6 sm:flex-row sm:items-center sm:p-7">
  {
    photo && (
      <Image
        src={photo}
        alt={FOUNDER.name}
        widths={[160, 320]}
        sizes="160px"
        class="h-28 w-28 shrink-0 rounded-full object-cover"
        loading="lazy"
      />
    )
  }
  <div>
    <p class="font-display text-xl font-semibold text-forest-900">{FOUNDER.name}</p>
    <p class="text-sm font-medium text-olive-500">{FOUNDER.jobTitle[locale]}</p>
    <p class="mt-2 text-sm leading-relaxed text-ink-soft">{FOUNDER.bio[locale]}</p>
    {
      FOUNDER.sameAs.length > 0 && (
        <p class="mt-2 flex gap-3 text-sm">
          {FOUNDER.sameAs.map((url) => (
            <a href={url} rel="me noopener" class="font-medium text-forest-700 underline decoration-chartreuse-400 underline-offset-4 hover:text-forest-800">
              {new URL(url).hostname.replace('www.', '')}
            </a>
          ))}
        </p>
      )
    }
  </div>
</aside>
