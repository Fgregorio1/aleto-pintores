---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { servicioPath } from '@/lib/paths';
import { useTranslations, type Locale } from '@/i18n/ui';

/**
 * Value-first card: no prices here (docs/03 §3b — visible prices live only
 * in FAQ answers and the /precios/ cluster).
 */
interface Props {
  servicio: CollectionEntry<'servicios'>;
  locale: Locale;
}
const { servicio, locale } = Astro.props;
const t = useTranslations(locale);
---

<a
  href={servicioPath(servicio)}
  class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-white transition-all hover:-translate-y-0.5 hover:border-olive-400 hover:shadow-md h-full"
>
  {
    servicio.data.image && (
      <div class="overflow-hidden aspect-[16/10] border-b border-line">
        <Image
          src={servicio.data.image}
          alt={servicio.data.shortLabel}
          widths={[400, 600, 800]}
          sizes="(min-width: 1024px) 360px, (min-width: 640px) 50vw, 100vw"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
          loading="lazy"
        />
      </div>
    )
  }
  <div class="flex flex-1 flex-col justify-between p-6">
    <div>
      <h3 class="text-lg text-forest-900 group-hover:text-forest-700">{servicio.data.shortLabel}</h3>
      <p class="mt-2 text-sm leading-relaxed text-ink-soft">{servicio.data.excerpt}</p>
    </div>
    <p class="mt-5 text-sm font-semibold text-olive-600">
      {t('card.ver')} <span aria-hidden="true" class="ml-1 inline-block transition-transform group-hover:translate-x-0.5">→</span>
    </p>
  </div>
</a>
