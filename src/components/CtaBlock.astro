---
import { useTranslations, type Locale } from '@/i18n/ui';
import { staticPath } from '@/i18n/routes';
import { BUSINESS, whatsappLink } from '@/data/business';

/** Conversion block: WhatsApp (primary), phone, and the contact form. */
interface Props {
  locale: Locale;
  /** Prefilled WhatsApp message; defaults per locale */
  message?: string;
  title?: string;
}
const { locale, message, title } = Astro.props;
const t = useTranslations(locale);
const heading =
  title ?? (locale === 'es' ? '¿Te damos un precio cerrado?' : 'Want a fixed quote?');
const sub =
  locale === 'es'
    ? 'Mándanos fotos por WhatsApp y te damos un presupuesto orientativo hoy mismo. Visita y presupuesto cerrado en 24 h, sin compromiso.'
    : 'Send us photos on WhatsApp and get an estimate today. On-site visit and fixed quote within 24 h, no obligation.';
const msg =
  message ??
  (locale === 'es'
    ? 'Hola, me gustaría pedir un presupuesto de pintura.'
    : 'Hi, I would like to request a painting quote.');
---

<section class="mt-16 rounded-2xl bg-brand-gradient p-8 text-paper sm:p-10">
  <h2 class="max-w-xl text-2xl text-paper sm:text-3xl">{heading}</h2>
  <p class="mt-3 max-w-xl leading-relaxed text-paper/90">{sub}</p>
  <div class="mt-6 flex flex-wrap items-center gap-3">
    <a
      href={whatsappLink(msg)}
      data-pos="cta" class="rounded-full bg-paper px-6 py-3 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]"
    >{t('cta.whatsapp')}</a>
    <a
      href={`tel:${BUSINESS.phoneE164}`}
      data-pos="cta" class="rounded-full border border-paper/50 px-6 py-3 text-sm font-semibold text-paper hover:border-paper"
    >{t('cta.llamar')}: {BUSINESS.phoneDisplay}</a>
    <a href={staticPath('presupuesto-gratis', locale)} class="text-sm font-medium text-paper/90 underline underline-offset-4 hover:text-paper">
      {t('cta.presupuesto')} →
    </a>
  </div>
</section>
