---
import type { Locale } from '@/i18n/ui';

/**
 * Google-review cards (Wolf pattern). GATED: renders nothing until real
 * reviews exist in src/data/reviews/*.yaml — never fabricate social proof.
 */
interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const files = import.meta.glob('/src/data/reviews/*.yaml', { eager: true });
type Review = { author: string; text: { es: string; en?: string }; rating?: number; source?: string };
const reviews = Object.values(files)
  .map((m: any) => m.default as Review)
  .filter((r) => r?.author && r?.text)
  .slice(0, 3);
---

{
  reviews.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <h2 class="text-center text-2xl text-forest-900 sm:text-3xl">
        {locale === 'es' ? 'Lo que dicen nuestros clientes' : 'What our clients say'}
      </h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {reviews.map((r) => (
          <figure class="rounded-2xl border border-line bg-white p-6">
            <div class="flex gap-0.5 text-chartreuse-500" aria-label={`${r.rating ?? 5}/5`}>
              {Array.from({ length: r.rating ?? 5 }).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.5 15 9l7 .8-5.2 4.7 1.4 6.9L12 17.9l-6.2 3.5 1.4-6.9L2 9.8 9 9l3-6.5Z" />
                </svg>
              ))}
            </div>
            <blockquote class="mt-3 text-sm leading-relaxed text-ink">{r.text[locale] ?? r.text.es}</blockquote>
            <figcaption class="mt-3 text-sm font-semibold text-forest-900">
              {r.author}
              <span class="ml-2 font-normal text-ink-soft">{r.source ?? 'Google'}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  )
}
