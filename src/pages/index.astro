---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import Faq from '@/components/Faq.astro';
import ContactSection from '@/components/contact/ContactSection.astro';
import WhatsAppIcon from '@/components/WhatsAppIcon.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { staticPath } from '@/i18n/routes';
import { BUSINESS, whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';
import preciosData from '@/data/precios.yaml';

const pagina = await getEntry('paginas', 'es/home');
if (!pagina) throw new Error('Missing paginas entry: es/home');
const seo = seoFromPagina(pagina);

const servicios = (await getCollection('servicios', (e) => e.id.startsWith('es/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const guias = (await getCollection('precios', (e) => e.id.startsWith('es/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const trust = [
  { title: 'Tu casa, protegida de verdad', text: 'Suelos, muebles y carpintería cubiertos antes de empezar. Lijado con aspiración, pintura sin olor y limpieza cada tarde.' },
  { title: 'Fechas y precio por escrito', text: 'Inicio, entrega y presupuesto cerrado firmados antes de empezar. Si surge algo que no vimos, lo asumimos nosotros.' },
  { title: 'El mismo equipo, con nombre', text: 'Las personas que conoces el primer día son las que terminan la obra. Con seguro de responsabilidad civil y un responsable al que llamar.' },
];

const metodo = [
  { paso: 'Visita y escucha', detalle: 'Vemos tu casa, medimos y entendemos qué buscas. Presupuesto cerrado por escrito en 24 h, con fechas.' },
  { paso: 'Protección total', detalle: 'El primer día se cubre todo lo que no se pinta. La casa sigue siendo habitable durante la obra.' },
  { paso: 'Preparación a conciencia', detalle: 'Grietas selladas, manchas tratadas, lijado fino. El 70% del resultado ocurre antes de la pintura.' },
  { paso: 'Entrega a contraluz', detalle: 'Repaso contigo pared a pared con luz rasante, limpieza final y garantía por escrito.' },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(pagina.data.faq)]}>
  <!-- Hero -->
  <section class="bg-brand-gradient text-paper">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-chartreuse-300">
        {BUSINESS.address.district}, {BUSINESS.address.city} · {BUSINESS.hoursDisplay.es}
      </p>
      <h1 class="mt-4 max-w-2xl text-4xl leading-tight sm:text-5xl lg:text-6xl">{pagina.data.h1}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-paper/90">{pagina.data.heroLead ?? pagina.data.directAnswer}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={whatsappLink(WHATSAPP_DEFAULT_MSG.es)} data-pos="hero" class="rounded-full bg-paper px-7 py-3.5 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]">
          Presupuesto por WhatsApp
        </a>
        <a href={staticPath('precios-hub', 'es')} class="rounded-full border border-paper/50 px-7 py-3.5 text-sm font-semibold text-paper hover:border-paper">
          Ver todos los precios
        </a>
      </div>
      <p class="mt-6 flex flex-wrap items-center gap-1.5 text-sm text-paper/80">
        <a href={whatsappLink(WHATSAPP_DEFAULT_MSG.es)} data-pos="hero-phone" class="inline-flex items-center gap-1.5 font-semibold underline decoration-chartreuse-400 underline-offset-4">
          <WhatsAppIcon />
          {BUSINESS.phoneDisplay}
        </a>
        — respuesta inmediata, también fines de semana
      </p>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-b border-line bg-white">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-3 sm:px-6">
      {trust.map((item) => (
        <div>
          <h2 class="font-sans text-base font-semibold tracking-normal text-forest-900">{item.title}</h2>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{item.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="mx-auto max-w-6xl px-4 pt-16 sm:px-6">
    <h2 class="text-3xl text-forest-900 sm:text-4xl">Qué hacemos</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      Cada servicio con su proceso paso a paso, las preguntas que todo el mundo hace y sus tarifas de {preciosData.anio}.
    </p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {servicios.map((s) => <ServiceCard servicio={s} locale="es" />)}
    </div>
  </section>

  <!-- Method -->
  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <h2 class="text-3xl text-forest-900 sm:text-4xl">Un método que puedes comprobar</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      Cada obra sigue los mismos cuatro pasos, tenga 12 m² o 300. Es lo que hace que el resultado no dependa de la suerte.
    </p>
    <ol class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {metodo.map((p, i) => (
        <li class="rounded-2xl border border-line bg-white p-5">
          <span class="font-display text-3xl font-semibold text-olive-400">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-2 font-sans text-base font-semibold tracking-normal text-forest-900">{p.paso}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{p.detalle}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- Price transparency -->
  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <div class="rounded-2xl border border-olive-400/40 bg-chartreuse-100/40 p-8 sm:p-10">
      <div class="grid items-center gap-8 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl text-forest-900">Y sí: los precios están publicados</h2>
          <p class="mt-4 leading-relaxed text-ink">
            Tarifas reales de presupuestos reales, publicadas y actualizadas cada trimestre — para que puedas
            compararnos antes incluso de llamarnos. Los números viven en su sitio: la sección de precios.
          </p>
          <a href={staticPath('precios-hub', 'es')} class="mt-6 inline-block rounded-full bg-forest-700 px-6 py-3 text-sm font-semibold text-paper hover:bg-forest-800">
            Calcular mi presupuesto →
          </a>
        </div>
        <ul class="space-y-3">
          {guias.map((g) => (
            <li>
              <a href={`/precios/${g.id.replace('es/', '')}/`} class="flex items-center justify-between rounded-xl border border-line bg-white px-5 py-3.5 text-sm font-medium text-forest-800 transition-colors hover:border-olive-400">
                {g.data.shortLabel}
                <span class="text-olive-500" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Zones -->
  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <h2 class="text-3xl text-forest-900">Trabajamos en todo Madrid</h2>
    <p class="mt-3 max-w-3xl leading-relaxed text-ink-soft">
      Con base en {BUSINESS.address.district}, damos servicio en Madrid capital y toda el área metropolitana:
      {BUSINESS.areaServed.join(', ')}. Visita y presupuesto gratuitos en cualquiera de estas zonas.
    </p>
  </section>

  <!-- FAQ -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <Faq faq={pagina.data.faq} locale="es" />
  </div>

  <ContactSection locale="es" formSource="home" />
</BaseLayout>
