---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import Faq from '@/components/Faq.astro';
import EstimateSection from '@/components/EstimateSection.astro';
import TestimonialsBlock from '@/components/TestimonialsBlock.astro';
import WhatsAppIcon from '@/components/WhatsAppIcon.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { BUSINESS, whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';

import heroImg from '@/assets/servicios/pintura-interior.jpg';

/**
 * Wolf-blueprint home (2026-07-19 full CRO rebuild): photo hero →
 * service grid → highlight callouts → reviews (gated) → estimate form →
 * stats → gallery → FAQ. Short copy, no prices, form comes to the visitor.
 */
const pagina = await getEntry('paginas', 'es/home');
if (!pagina) throw new Error('Missing paginas entry: es/home');
const seo = seoFromPagina(pagina);

const servicios = (await getCollection('servicios', (e) => e.id.startsWith('es/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const highlights = [
  {
    title: 'Sin polvo por toda la casa',
    text: 'Estancias selladas y lijado con aspiración industrial. La mayoría de nuestros clientes no se muda durante la obra.',
  },
  {
    title: 'Fechas que se cumplen',
    text: 'Inicio y entrega por escrito antes de empezar. Si nos retrasamos por nuestra culpa, te compensamos.',
  },
  {
    title: 'Oficio de verdad',
    text: '7 años dirigiendo una empresa de pintura en Estados Unidos, ahora aplicando ese estándar en Madrid.',
  },
];

---

<BaseLayout seo={seo} schemas={[faqSchema(pagina.data.faq)]}>
  <!-- Hero: photo background, short claim, dual CTA -->
  <section class="relative overflow-hidden">
    <Image
      src={heroImg}
      alt=""
      widths={[800, 1400, 2000]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-forest-950/70"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 text-paper sm:px-6 sm:py-28">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-chartreuse-300">{BUSINESS.address.city} · Comunidad de Madrid</p>
      <h1 class="mt-4 max-w-2xl text-4xl leading-tight sm:text-5xl lg:text-6xl">{pagina.data.h1}</h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-paper/90">
        Pintura interior, quitar gotelé y lacado con protección total, fechas por contrato y presupuesto cerrado en 24 horas.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={whatsappLink(WHATSAPP_DEFAULT_MSG.es)} data-pos="hero" class="inline-flex items-center gap-2 rounded-full bg-paper px-7 py-3.5 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]">
          <WhatsAppIcon size={15} />
          Presupuesto por WhatsApp
        </a>
        <a href="#contacto" class="rounded-full border border-paper/50 px-7 py-3.5 text-sm font-semibold text-paper hover:border-paper">
          Pedir visita gratuita
        </a>
      </div>
      <ul class="mt-8 flex flex-wrap gap-x-5 gap-y-2">
        {
          ['Asegurados (RC 300.000 €)', 'Garantía por escrito', 'Fechas por contrato'].map((c) => (
            <li class="flex items-center gap-1.5 text-sm text-paper/90">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="text-chartreuse-300"><path d="M2 6.5 4.8 9.2 10 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {c}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Services grid -->
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <h2 class="text-2xl text-forest-900 sm:text-3xl">Nuestros servicios</h2>
    <div class="mt-7 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {servicios.map((s) => <ServiceCard servicio={s} locale="es" />)}
    </div>
  </section>

  <!-- Highlight callouts -->
  <section class="border-y border-line bg-paper-dark/40">
    <div class="mx-auto grid max-w-6xl gap-5 px-4 py-12 sm:px-6 lg:grid-cols-3">
      {
        highlights.map((h) => (
          <div class="rounded-2xl border border-line bg-white p-6">
            <h3 class="font-sans text-base font-semibold tracking-normal text-forest-900">{h.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{h.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <TestimonialsBlock locale="es" />

  <EstimateSection locale="es" formSource="home" />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <Faq faq={pagina.data.faq} locale="es" />
  </div>
</BaseLayout>
