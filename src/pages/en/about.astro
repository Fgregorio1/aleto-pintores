---
import { getEntry } from 'astro:content';
import PaginaLayout from '@/layouts/PaginaLayout.astro';
import { founderSchema } from '@/lib/schema';

const entry = await getEntry('paginas', 'en/about');
if (!entry) throw new Error('Missing paginas entry: en/about');

const schemas = [
  founderSchema({ name: 'Felipe Gregorio', jobTitle: 'Founder' })
];
---

<PaginaLayout entry={entry} extraSchemas={schemas} />
