---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DirectAnswer from '@/components/DirectAnswer.astro';
import ContactSection from '@/components/contact/ContactSection.astro';
import FounderCard from '@/components/FounderCard.astro';
import Faq from '@/components/Faq.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { BUSINESS } from '@/data/business';

const entry = await getEntry('paginas', 'en/contact');
if (!entry) throw new Error('Missing paginas entry: en/contact');
const seo = seoFromPagina(entry);
const crumbs = [
  { name: 'Home', path: '/en/' },
  { name: 'Contact', path: seo.canonicalPath },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(entry.data.faq)]}>
  <Breadcrumbs items={crumbs} />
  <section class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <h1 class="text-3xl leading-tight text-forest-900 sm:text-4xl lg:text-[2.75rem]">{entry.data.h1}</h1>
    {entry.data.directAnswer && <DirectAnswer text={entry.data.directAnswer} />}
  </section>

  <section class="mx-auto max-w-6xl px-4 mt-8 sm:px-6">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      <div class="flex flex-col justify-between rounded-2xl border border-line bg-white p-6 shadow-sm">
        <div>
          <h2 class="text-xl font-bold text-forest-900 font-display">About our founder</h2>
          <p class="mt-2 text-sm text-ink-soft">Meet the person directing and supervising the methodology and quality standards of Aleto Pintores.</p>
        </div>
        <FounderCard locale="en" />
      </div>
      <div class="rounded-2xl border border-line bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-forest-900 font-display">Legal Registration & Security Guarantees</h2>
        <p class="mt-2 text-sm leading-relaxed text-ink-soft">
          We operate under strict legality and transparency. All our projects are fully covered by liability insurance to protect your property from any accidental issues.
        </p>
        <ul class="mt-4 space-y-3.5 text-sm">
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>MAPFRE Insurance:</strong> Third-party liability coverage up to €300,000 per incident.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>Tax ID / Legal Name:</strong> {BUSINESS.legalName} (NIF: {BUSINESS.taxId})</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>Headquarters Address:</strong> {BUSINESS.addressDisplay} (Chamberí, Madrid)</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>Written Contract:</strong> Binding estimates and completion deadlines signed on contract.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <ContactSection locale="en" formSource="contact" />

  <section class="mx-auto max-w-6xl px-4 sm:px-6">
    <Faq faq={entry.data.faq} locale="en" />
  </section>
</BaseLayout>
