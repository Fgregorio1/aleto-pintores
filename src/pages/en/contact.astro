---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DirectAnswer from '@/components/DirectAnswer.astro';
import ContactForm from '@/components/islands/ContactForm.astro';
import Faq from '@/components/Faq.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { BUSINESS, whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';

const entry = await getEntry('paginas', 'en/contact');
if (!entry) throw new Error('Missing paginas entry: en/contact');
const seo = seoFromPagina(entry);
const crumbs = [
  { name: 'Home', path: '/en/' },
  { name: 'Contact', path: seo.canonicalPath },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(entry.data.faq)]}>
  <Breadcrumbs items={crumbs} />
  <section class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <h1 class="text-3xl leading-tight text-forest-900 sm:text-4xl lg:text-[2.75rem]">{entry.data.h1}</h1>
    {entry.data.directAnswer && <DirectAnswer text={entry.data.directAnswer} />}

    <div class="mt-10 grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl text-forest-900">Write to us</h2>
        <ContactForm locale="en" />
      </div>
      <div>
        <h2 class="text-2xl text-forest-900">Direct contact</h2>
        <ul class="mt-6 space-y-4 text-sm">
          <li class="rounded-2xl border border-line bg-white p-5">
            <p class="font-semibold text-forest-900">WhatsApp & phone</p>
            <p class="mt-1">
              <a href={whatsappLink(WHATSAPP_DEFAULT_MSG.en)} class="font-medium text-forest-700 underline decoration-chartreuse-400 decoration-2 underline-offset-2">WhatsApp: {BUSINESS.phoneDisplay}</a>
              <span class="mx-2 text-line">·</span>
              <a href={`tel:${BUSINESS.phoneE164}`} class="font-medium text-forest-700 underline decoration-chartreuse-400 decoration-2 underline-offset-2">Call</a>
            </p>
            <p class="mt-1 text-ink-soft">{BUSINESS.hoursDisplay.en}</p>
          </li>
          <li class="rounded-2xl border border-line bg-white p-5">
            <p class="font-semibold text-forest-900">Email</p>
            <a href={`mailto:${BUSINESS.email}`} class="mt-1 inline-block font-medium text-forest-700 underline decoration-chartreuse-400 decoration-2 underline-offset-2">{BUSINESS.email}</a>
          </li>
          <li class="rounded-2xl border border-line bg-white p-5">
            <p class="font-semibold text-forest-900">Address</p>
            <p class="mt-1 text-ink">{BUSINESS.addressDisplay}</p>
            <p class="mt-1 text-ink-soft">Serving Madrid city and the metro area</p>
          </li>
        </ul>
      </div>
    </div>

    <Faq faq={entry.data.faq} locale="en" />
  </section>
</BaseLayout>
