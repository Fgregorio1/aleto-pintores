---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import Faq from '@/components/Faq.astro';
import CtaBlock from '@/components/CtaBlock.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { staticPath } from '@/i18n/routes';
import { BUSINESS, whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';
import preciosData from '@/data/precios.yaml';

const pagina = await getEntry('paginas', 'en/home');
if (!pagina) throw new Error('Missing paginas entry: en/home');
const seo = seoFromPagina(pagina);

const servicios = (await getCollection('servicios', (e) => e.id.startsWith('en/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const guias = (await getCollection('precios', (e) => e.id.startsWith('en/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const nf = new Intl.NumberFormat('en-GB');
const p80 = preciosData.servicios['pintura-interior'].ejemplos.find((e: any) => e.m2 === 80);

const trust = [
  { title: 'Published prices', text: 'Real rates on the website, updated quarterly. Benchmark us before you even call.' },
  { title: 'Fixed quote within 24 h', text: 'Free visit, written price the next day. It never grows mid-job.' },
  { title: 'Invoice, insurance & warranty', text: 'VAT invoice always, current liability insurance and a written warranty.' },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(pagina.data.faq)]}>
  <section class="bg-brand-gradient text-paper">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-chartreuse-300">
        {BUSINESS.address.district}, {BUSINESS.address.city} · {BUSINESS.hoursDisplay.en}
      </p>
      <h1 class="mt-4 max-w-2xl text-4xl leading-tight sm:text-5xl lg:text-6xl">{pagina.data.h1}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-paper/90">{pagina.data.directAnswer}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={whatsappLink(WHATSAPP_DEFAULT_MSG.en)} class="rounded-full bg-paper px-7 py-3.5 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]">
          Get a quote on WhatsApp
        </a>
        <a href={staticPath('precios-hub', 'en')} class="rounded-full border border-paper/50 px-7 py-3.5 text-sm font-semibold text-paper hover:border-paper">
          See all prices
        </a>
      </div>
      <p class="mt-6 text-sm text-paper/80">
        <a href={`tel:${BUSINESS.phoneE164}`} class="font-semibold underline decoration-chartreuse-400 underline-offset-4">{BUSINESS.phoneDisplay}</a>
        — immediate reply, weekends included
      </p>
    </div>
  </section>

  <section class="border-b border-line bg-white">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-3 sm:px-6">
      {trust.map((item) => (
        <div>
          <h2 class="font-sans text-base font-semibold tracking-normal text-forest-900">{item.title}</h2>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{item.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-16 sm:px-6">
    <h2 class="text-3xl text-forest-900 sm:text-4xl">Services with published prices</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      Every service with its {preciosData.anio} rates, the step-by-step process, and the questions everyone asks.
    </p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {servicios.map((s) => <ServiceCard servicio={s} locale="en" />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <div class="rounded-2xl border border-olive-400/40 bg-chartreuse-100/40 p-8 sm:p-10">
      <div class="grid items-center gap-8 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl text-forest-900">How much? It's published.</h2>
          <p class="mt-4 leading-relaxed text-ink">
            Almost no painting company publishes prices. We do: painting an 80 m² flat costs between
            <strong>€{nf.format(p80.min)}</strong> and <strong>€{nf.format(p80.max)}</strong> in {preciosData.anio}, and removing that same flat's gotelé texture between
            <strong>€1,800</strong> and <strong>€2,600</strong>, painting included. Real ranges from real quotes, updated quarterly.
          </p>
          <a href={staticPath('precios-hub', 'en')} class="mt-6 inline-block rounded-full bg-forest-700 px-6 py-3 text-sm font-semibold text-paper hover:bg-forest-800">
            Estimate my project →
          </a>
        </div>
        <ul class="space-y-3">
          {guias.map((g) => (
            <li>
              <a href={`/en/prices/${g.id.replace('en/', '')}/`} class="flex items-center justify-between rounded-xl border border-line bg-white px-5 py-3.5 text-sm font-medium text-forest-800 transition-colors hover:border-olive-400">
                {g.data.shortLabel}
                <span class="text-olive-500" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <h2 class="text-3xl text-forest-900">Serving all of Madrid</h2>
    <p class="mt-3 max-w-3xl leading-relaxed text-ink-soft">
      Based in {BUSINESS.address.district}, we serve Madrid city and the whole metro area:
      {BUSINESS.areaServed.join(', ')}. Free visits and quotes anywhere in these areas.
    </p>
  </section>

  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <Faq faq={pagina.data.faq} locale="en" />
    <CtaBlock locale="en" />
  </div>
</BaseLayout>
