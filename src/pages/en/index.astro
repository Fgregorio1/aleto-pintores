---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import Faq from '@/components/Faq.astro';
import ContactSection from '@/components/contact/ContactSection.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { staticPath } from '@/i18n/routes';
import { BUSINESS, whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';
import preciosData from '@/data/precios.yaml';

const pagina = await getEntry('paginas', 'en/home');
if (!pagina) throw new Error('Missing paginas entry: en/home');
const seo = seoFromPagina(pagina);

const servicios = (await getCollection('servicios', (e) => e.id.startsWith('en/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const guias = (await getCollection('precios', (e) => e.id.startsWith('en/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const trust = [
  { title: 'Your home, properly protected', text: 'Floors, furniture and joinery covered before we start. Dust-extracted sanding, odourless paint and a cleanup every evening.' },
  { title: 'Dates and price in writing', text: 'Start, delivery and a fixed quote signed before we begin. Anything we missed at the visit is on us.' },
  { title: 'The same crew, with names', text: 'The people you meet on day one finish the job. Liability-insured, with one direct contact you can call.' },
];

const metodo = [
  { paso: 'Visit & listen', detalle: 'We see your home, measure and understand what you want. Fixed written quote in 24 h, with dates.' },
  { paso: 'Full protection', detalle: 'Day one, everything that isn’t painted gets covered. The home stays livable throughout.' },
  { paso: 'Proper preparation', detalle: 'Cracks sealed, stains blocked, fine sanding. 70% of the result happens before the paint.' },
  { paso: 'Raking-light handover', detalle: 'A wall-by-wall review with you under raking light, final clean and written warranty.' },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(pagina.data.faq)]}>
  <section class="bg-brand-gradient text-paper">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-chartreuse-300">
        {BUSINESS.address.district}, {BUSINESS.address.city} · {BUSINESS.hoursDisplay.en}
      </p>
      <h1 class="mt-4 max-w-2xl text-4xl leading-tight sm:text-5xl lg:text-6xl">{pagina.data.h1}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-paper/90">{pagina.data.heroLead ?? pagina.data.directAnswer}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={whatsappLink(WHATSAPP_DEFAULT_MSG.en)} data-pos="hero" class="rounded-full bg-paper px-7 py-3.5 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]">
          Get a quote on WhatsApp
        </a>
        <a href={staticPath('precios-hub', 'en')} class="rounded-full border border-paper/50 px-7 py-3.5 text-sm font-semibold text-paper hover:border-paper">
          See all prices
        </a>
      </div>
      <p class="mt-6 text-sm text-paper/80">
        <a href={`tel:${BUSINESS.phoneE164}`} class="font-semibold underline decoration-chartreuse-400 underline-offset-4">{BUSINESS.phoneDisplay}</a>
        — immediate reply, weekends included
      </p>
    </div>
  </section>

  <section class="border-b border-line bg-white">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-3 sm:px-6">
      {trust.map((item) => (
        <div>
          <h2 class="font-sans text-base font-semibold tracking-normal text-forest-900">{item.title}</h2>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{item.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-16 sm:px-6">
    <h2 class="text-3xl text-forest-900 sm:text-4xl">What we do</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      Every service with its step-by-step process, the questions everyone asks, and its {preciosData.anio} rates.
    </p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {servicios.map((s) => <ServiceCard servicio={s} locale="en" />)}
    </div>
  </section>

  <!-- Method -->
  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <h2 class="text-3xl text-forest-900 sm:text-4xl">A method you can verify</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      Every job follows the same four steps, whether it's 12 m² or 300. It's what keeps the result from depending on luck.
    </p>
    <ol class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {metodo.map((p, i) => (
        <li class="rounded-2xl border border-line bg-white p-5">
          <span class="font-display text-3xl font-semibold text-olive-400">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-2 font-sans text-base font-semibold tracking-normal text-forest-900">{p.paso}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{p.detalle}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <div class="rounded-2xl border border-olive-400/40 bg-chartreuse-100/40 p-8 sm:p-10">
      <div class="grid items-center gap-8 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl text-forest-900">And yes: the prices are published</h2>
          <p class="mt-4 leading-relaxed text-ink">
            Real rates from real quotes, published and updated quarterly — so you can benchmark us before you
            even call. The numbers live where they belong: on the prices page.
          </p>
          <a href={staticPath('precios-hub', 'en')} class="mt-6 inline-block rounded-full bg-forest-700 px-6 py-3 text-sm font-semibold text-paper hover:bg-forest-800">
            Estimate my project →
          </a>
        </div>
        <ul class="space-y-3">
          {guias.map((g) => (
            <li>
              <a href={`/en/prices/${g.id.replace('en/', '')}/`} class="flex items-center justify-between rounded-xl border border-line bg-white px-5 py-3.5 text-sm font-medium text-forest-800 transition-colors hover:border-olive-400">
                {g.data.shortLabel}
                <span class="text-olive-500" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-20 sm:px-6">
    <h2 class="text-3xl text-forest-900">Serving all of Madrid</h2>
    <p class="mt-3 max-w-3xl leading-relaxed text-ink-soft">
      Based in {BUSINESS.address.district}, we serve Madrid city and the whole metro area:
      {BUSINESS.areaServed.join(', ')}. Free visits and quotes anywhere in these areas.
    </p>
  </section>

  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <Faq faq={pagina.data.faq} locale="en" />
  </div>

  <ContactSection locale="en" formSource="home" />
</BaseLayout>
