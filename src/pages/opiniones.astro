---
import { getCollection, getEntry } from 'astro:content';
import PaginaLayout from '@/layouts/PaginaLayout.astro';
import { opinionesIndexable } from '@/lib/gates';

const entry = await getEntry('paginas', 'es/opiniones');
if (!entry) throw new Error('Missing paginas entry: es/opiniones');
const reviews = await getCollection('reviews');
// Quality gate: page stays noindex until ≥3 real reviews exist.
// To open it for indexing: set noindex: false in the paginas entry once reviews are in.
const indexable = opinionesIndexable(reviews);
const sorted = reviews.sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());
---

<PaginaLayout entry={entry}>
  {
    indexable && (
      <section class="mt-10">
        <ul class="grid gap-4 sm:grid-cols-2">
          {sorted.map((r) => (
            <li class="rounded-2xl border border-line bg-white p-5">
              <p class="text-chartreuse-500" aria-label={`${r.data.rating} de 5`}>{'★'.repeat(r.data.rating)}</p>
              <p class="mt-2 text-sm leading-relaxed text-ink">"{r.data.texto}"</p>
              <p class="mt-3 text-xs font-medium text-ink-soft">
                {r.data.autor} · {r.data.fuente}
                {r.data.zonaSlug && ` · ${r.data.zonaSlug}`}
              </p>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</PaginaLayout>
