---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import EstimateSection from '@/components/EstimateSection.astro';
import StatsBand from '@/components/StatsBand.astro';
import TrustGarantias from '@/components/TrustGarantias.astro';
import WhatsAppIcon from '@/components/WhatsAppIcon.astro';
import type { SEOData } from '@/lib/seo';
import { whatsappLink, WHATSAPP_DEFAULT_MSG } from '@/data/business';
import { TOWNS, type Town } from '@/data/towns';

/**
 * Town landing pages for the Zona ad group (2026-07-19 CRO rebuild,
 * Wolf "Areas We Serve" pattern). Pure ad landers: noindex, short copy,
 * form on-page. Supersedes the old quality-gated zonas system (retired
 * with the SEO strategy; src/data/zonas + ZonaLayout remain dormant).
 */
export async function getStaticPaths() {
  return TOWNS.map((town) => ({ params: { zona: town.slug }, props: { town } }));
}

interface Props {
  town: Town;
}
const { town } = Astro.props;

const seo: SEOData = {
  title: `Pintores ${town.en} — Presupuesto cerrado en 24 h`,
  description: `${town.intro} Seguro de RC, garantía por escrito y el mismo equipo del primer al último día.`,
  canonicalPath: `/pintores/${town.slug}/`,
  locale: 'es',
  alternates: [],
  noindex: true,
};

const servicios = (await getCollection('servicios', (e) => e.id.startsWith('es/') && !e.data.draft))
  .sort((a, b) => a.data.orden - b.data.orden)
  .slice(0, 6);
---

<BaseLayout seo={seo}>
  <header class="bg-brand-gradient text-paper">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-20">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-chartreuse-300">Comunidad de Madrid</p>
      <h1 class="mt-4 max-w-2xl text-4xl leading-tight sm:text-5xl">Pintores {town.en}</h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-paper/90">{town.intro}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={whatsappLink(WHATSAPP_DEFAULT_MSG.es)}
          data-pos="hero"
          class="inline-flex items-center gap-2 rounded-full bg-paper px-7 py-3.5 text-sm font-semibold text-forest-900 transition-transform hover:scale-[1.02]"
        >
          <WhatsAppIcon size={15} />
          Presupuesto por WhatsApp
        </a>
        <a href="#contacto" class="rounded-full border border-paper/50 px-7 py-3.5 text-sm font-semibold text-paper hover:border-paper">
          Pedir visita gratuita
        </a>
      </div>
      <p class="mt-5 text-sm text-paper/80">
        Atendemos todo {town.name}: {town.barrios.join(', ')} y el resto del municipio.
      </p>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <h2 class="text-2xl text-forest-900 sm:text-3xl">Qué hacemos {town.en}</h2>
    <div class="mt-7 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {servicios.map((s) => <ServiceCard servicio={s} locale="es" />)}
    </div>
  </section>

  <section class="border-y border-line bg-paper-dark/40">
    <div class="mx-auto grid max-w-6xl items-start gap-10 px-4 py-12 sm:px-6 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl text-forest-900 sm:text-3xl">Garantías en cada trabajo</h2>
        <p class="mt-2 max-w-md text-ink-soft">Mismo estándar en {town.name} que en cualquier punto de Madrid: por escrito y sin letra pequeña.</p>
      </div>
      <TrustGarantias locale="es" />
    </div>
  </section>

  <EstimateSection locale="es" formSource={`zona_${town.slug}`} />

  <StatsBand locale="es" />
</BaseLayout>
