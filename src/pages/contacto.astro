---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DirectAnswer from '@/components/DirectAnswer.astro';
import ContactSection from '@/components/contact/ContactSection.astro';
import FounderCard from '@/components/FounderCard.astro';
import Faq from '@/components/Faq.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import { BUSINESS } from '@/data/business';

const entry = await getEntry('paginas', 'es/contacto');
if (!entry) throw new Error('Missing paginas entry: es/contacto');
const seo = seoFromPagina(entry);
const crumbs = [
  { name: 'Inicio', path: '/' },
  { name: 'Contacto', path: seo.canonicalPath },
];
---

<BaseLayout seo={seo} schemas={[faqSchema(entry.data.faq)]}>
  <Breadcrumbs items={crumbs} />
  <section class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <h1 class="text-3xl leading-tight text-forest-900 sm:text-4xl lg:text-[2.75rem]">{entry.data.h1}</h1>
    {entry.data.directAnswer && <DirectAnswer text={entry.data.directAnswer} />}
  </section>

  <section class="mx-auto max-w-6xl px-4 mt-8 sm:px-6">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      <div class="flex flex-col justify-between rounded-2xl border border-line bg-white p-6 shadow-sm">
        <div>
          <h2 class="text-xl font-bold text-forest-900 font-display">Sobre nuestro fundador</h2>
          <p class="mt-2 text-sm text-ink-soft">Conoce a la persona que dirige y supervisa la metodología y los estándares de calidad de Aleto Pintores.</p>
        </div>
        <FounderCard locale="es" />
      </div>
      <div class="rounded-2xl border border-line bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-forest-900 font-display">Registro Legal y Garantías de Seguridad</h2>
        <p class="mt-2 text-sm leading-relaxed text-ink-soft">
          Operamos bajo la más estricta legalidad y transparencia. Todos nuestros proyectos cuentan con seguro de responsabilidad civil para proteger tu inmueble de cualquier percance.
        </p>
        <ul class="mt-4 space-y-3.5 text-sm">
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>Seguro MAPFRE:</strong> Cobertura de hasta 300.000 € por siniestro para tu total tranquilidad.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>CIF/NIF Legal:</strong> {BUSINESS.legalName} (NIF: {BUSINESS.taxId})</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>Sede y dirección física:</strong> {BUSINESS.addressDisplay} (Chamberí, Madrid)</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-forest-700 font-bold" aria-hidden="true">✓</span>
            <span><strong>Garantía por escrito:</strong> Presupuestos vinculantes firmados y plazos garantizados por contrato.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <ContactSection locale="es" formSource="contact" />

  <section class="mx-auto max-w-6xl px-4 sm:px-6">
    <Faq faq={entry.data.faq} locale="es" />
  </section>
</BaseLayout>
