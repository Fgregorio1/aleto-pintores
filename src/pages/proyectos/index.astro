---
import { getCollection, getEntry } from 'astro:content';
import PaginaLayout from '@/layouts/PaginaLayout.astro';
import { proyectoPath } from '@/lib/paths';

const entry = await getEntry('paginas', 'es/proyectos-hub');
if (!entry) throw new Error('Missing paginas entry: es/proyectos-hub');
const proyectos = (await getCollection('proyectos', (p) => !p.data.draft)).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime(),
);
// Gate: entry frontmatter keeps noindex:true until real projects exist.
const nf = new Intl.NumberFormat('es-ES');
---

<PaginaLayout entry={entry}>
  {
    proyectos.length > 0 && (
      <section class="mt-10">
        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {proyectos.map((p) => (
            <li>
              <a href={proyectoPath(p)} class="group block overflow-hidden rounded-2xl border border-line bg-white transition-all hover:-translate-y-0.5 hover:border-olive-400 hover:shadow-md">
                {p.data.imagenes[0] && (
                  <img src={p.data.imagenes[0].src} alt={p.data.imagenes[0].alt} loading="lazy" class="aspect-[4/3] w-full object-cover" />
                )}
                <div class="p-5">
                  <h2 class="text-lg text-forest-900 group-hover:text-forest-700">{p.data.h1}</h2>
                  <p class="mt-1.5 text-sm text-ink-soft">
                    {p.data.superficieM2} m² · {nf.format(p.data.precioTotal)} € · {p.data.duracionDias} días
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</PaginaLayout>
