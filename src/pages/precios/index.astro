---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DirectAnswer from '@/components/DirectAnswer.astro';
import PriceCalculator from '@/components/islands/PriceCalculator.astro';
import UpdatedDate from '@/components/UpdatedDate.astro';
import Faq from '@/components/Faq.astro';
import CtaBlock from '@/components/CtaBlock.astro';
import { seoFromPagina } from '@/lib/seo';
import { faqSchema } from '@/lib/schema';
import preciosData from '@/data/precios.yaml';

const pagina = await getEntry('paginas', 'es/precios-hub');
if (!pagina) throw new Error('Missing paginas entry: es/precios-hub');
const seo = seoFromPagina(pagina);
const guias = (await getCollection('precios', (e) => e.id.startsWith('es/') && !e.data.draft)).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const crumbs = [
  { name: 'Inicio', path: '/' },
  { name: 'Precios', path: seo.canonicalPath },
];
const nf = new Intl.NumberFormat('es-ES');
const resumen = Object.values(preciosData.servicios) as any[];
---

<BaseLayout seo={seo} schemas={[faqSchema(pagina.data.faq)]}>
  <Breadcrumbs items={crumbs} />
  <section class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
    <h1 class="text-3xl leading-tight text-forest-900 sm:text-4xl lg:text-[2.75rem]">{pagina.data.h1}</h1>
    <UpdatedDate date={new Date(preciosData.dateModified)} locale="es" />
    {pagina.data.directAnswer && <DirectAnswer text={pagina.data.directAnswer} />}

    <!-- Summary table of ALL services — from precios.yaml -->
    <div class="mt-10 overflow-x-auto">
      <table class="w-full min-w-[30rem] border-collapse text-sm">
        <caption class="mb-3 caption-top text-left text-base font-semibold text-forest-900">
          Tarifas {preciosData.anio} — todos los servicios
        </caption>
        <thead>
          <tr>
            <th class="bg-forest-900 px-3 py-2.5 text-left font-medium text-paper">Servicio</th>
            <th class="bg-forest-900 px-3 py-2.5 text-left font-medium text-paper">Precio {preciosData.anio}</th>
            <th class="bg-forest-900 px-3 py-2.5 text-left font-medium text-paper">Unidad</th>
          </tr>
        </thead>
        <tbody>
          {resumen.map((s: any) => (
            <tr>
              <td class="border-b border-line px-3 py-2.5 font-medium">{s.label_es}</td>
              <td class="border-b border-line px-3 py-2.5 font-semibold text-forest-800">{nf.format(s.min)}–{nf.format(s.max)} €</td>
              <td class="border-b border-line px-3 py-2.5 text-ink-soft">{s.unidad_es}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="mt-2 text-xs text-ink-soft">{preciosData.metodologia_es}</p>
    </div>

    <PriceCalculator locale="es" />

    <section class="mt-14">
      <h2 class="text-2xl text-forest-900 sm:text-3xl">Guías de precios en detalle</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {guias.map((g) => (
          <a href={`/precios/${g.id.replace('es/', '')}/`} class="group rounded-2xl border border-line bg-white p-6 transition-all hover:-translate-y-0.5 hover:border-olive-400 hover:shadow-md">
            <h3 class="text-lg text-forest-900 group-hover:text-forest-700">{g.data.h1}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{g.data.excerpt}</p>
          </a>
        ))}
      </div>
    </section>

    <Faq faq={pagina.data.faq} locale="es" />
    <CtaBlock locale="es" />
  </section>
</BaseLayout>
