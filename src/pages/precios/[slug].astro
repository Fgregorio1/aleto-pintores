---
import { getCollection } from 'astro:content';
import PrecioLayout from '@/layouts/PrecioLayout.astro';

export async function getStaticPaths() {
  const precios = await getCollection('precios', (e) => e.id.startsWith('es/') && !e.data.draft);
  return precios.map((entry) => ({
    params: { slug: entry.id.replace('es/', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<PrecioLayout entry={entry} />
