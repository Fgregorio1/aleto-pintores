# Cloudflare Pages headers

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Hashed build assets — cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Backstop: never index workers.dev hosts (the workers.dev route and preview
# URLs are disabled in wrangler.jsonc, but if ever re-enabled this rule keeps
# them out of search indexes). The only indexable host is aletopintores.com.
https://:worker.gregorio-inov.workers.dev/*
  X-Robots-Tag: noindex
